{
  "manifest_version": 3,
  "name": "Launchpad",
  "version": "1.1.0",
  "description": "A fast, developer-focused new tab dashboard with bookmark management, tab customization, and more.",
  "permissions": ["bookmarks", "favicon", "storage", "tabs", "scripting"],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
